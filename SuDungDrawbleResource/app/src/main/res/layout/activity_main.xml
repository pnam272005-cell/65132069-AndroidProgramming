<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nen_chuyen_tiep">

    <View
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@drawable/header_bg"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardProfile"
        android:layout_width="140dp"
        android:layout_height="140dp"
        app:cardCornerRadius="70dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.28">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@mipmap/profile_image" />
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnCong"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/green_rec_button"
        android:text="CỘNG"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:drawableTop="@android:drawable/ic_input_add"
        android:paddingTop="20dp"
        android:paddingBottom="10dp"
        app:backgroundTint="@null"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnTru" />

    <Button
        android:id="@+id/btnTru"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/red_circle_button"
        android:text="TRỪ"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:drawableTop="@android:drawable/checkbox_off_background"
        android:paddingTop="20dp"
        android:paddingBottom="10dp"
        app:backgroundTint="@null"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:layout_constraintStart_toEndOf="@+id/btnCong"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>